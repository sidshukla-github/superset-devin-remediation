# Devin API (Settings → Service Users in app.devin.ai)
DEVIN_API_KEY=cog_your_key_here
DEVIN_ORG_ID=org_your_org_id

# GitHub PAT with repo scope on the Superset fork
GITHUB_TOKEN=ghp_your_token_here

# Target Superset fork
TARGET_REPO=sidshukla-github/superset

# Webhook secret (set same value in fork repo webhook settings)
WEBHOOK_SECRET=change-me-to-a-random-string

# Optional tuning
REMEDIATION_LABEL=devin-remediate
MAX_ACU_LIMIT=15
POLL_INTERVAL_SECONDS=20
DRY_RUN=false
